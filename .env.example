# -----------------------------------------------------------------
# Copy this file to `.env` and adjust values for your environment.
# `.env` is git-ignored — never commit real secrets.
# -----------------------------------------------------------------

# Database
POSTGRES_DB=urban
POSTGRES_USER=urban
POSTGRES_PASSWORD=urban_dev_pw
POSTGRES_PORT=5432

# Backend
BACKEND_PORT=8080
JWT_SECRET=change-me-use-a-strong-random-secret-at-least-32-bytes-long
JWT_EXPIRY_MINUTES=1440
# SUPER_ADMIN is seeded on first boot and can create up to ADMIN_MAX_COUNT ADMINs.
SUPER_ADMIN_USERNAME=eparasmahajan@gmail.com
SUPER_ADMIN_PASSWORD=Paras@2002
ADMIN_MAX_COUNT=100

# Web
WEB_PORT=3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8080

# CORS — comma-separated origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# Brevo (email OTP) — leave empty for dev; OTPs log to backend console
BREVO_API_KEY=
MAIL_FROM=no-reply@urban.local

# Cloudinary (product image uploads) — leave empty for dev
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay — use test-mode keys during dev
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
